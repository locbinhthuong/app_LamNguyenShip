	<string>AloShipp Driver cần quyền truy cập vị trí của bạn kể cả khi ứng dụng chạy ngầm để có thể nhận đơn hàng gần nhất và chia sẻ lộ trình giao hàng trực tiếp cho khách hàng.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>AloShipp Driver cần quyền vị trí để xác định quãng đường và gợi ý đơn hàng xung quanh bạn.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>AloShipp Driver cần quyền truy cập Camera để bạn có thể chụp ảnh đại diện trực tiếp.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>AloShipp Driver cần quyền truy cập Thư viện ảnh để bạn có thể chọn ảnh đại diện cho hồ sơ của mình.</string>
